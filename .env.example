# CulinAIre Mobile — Environment variables
#
# Copy this file to `.env` (gitignored) and fill in real values for local
# development. For EAS builds, set these as EAS secrets via:
#   eas secret:create --scope project --name EXPO_PUBLIC_API_BASE_URL ...
#
# All EXPO_PUBLIC_* variables are baked into the JS bundle at build time
# and are visible to anyone who unpacks the APK. Do NOT put real secrets
# here. Client IDs are public values; client SECRETS belong server-side.

# Backend root (the deployed CulinAIre Kitchen API server). The mobile
# app talks to this for auth, sync, and (eventually) model download.
#
# IMPORTANT: must be the `www` host. The apex `culinaire.kitchen`
# 301-redirects to `www.culinaire.kitchen`, and Node/browser fetch strips
# the Authorization header on cross-origin redirects. That breaks Bearer
# auth on every GET (e.g. /api/auth/me). POST endpoints don't redirect,
# so the bug only surfaces on GETs.
EXPO_PUBLIC_API_BASE_URL=https://www.culinaire.kitchen

# Optional: only needed for `pnpm test:contract`. A real (verified, no-MFA)
# account in the prod DB used by the contract test suite to exercise the
# happy-path login + /me + refresh + logout chain. Skip these to leave the
# 4 auth-required contract tests in skipped state.
# CONTRACT_TEST_EMAIL=
# CONTRACT_TEST_PASSWORD=

# Google OAuth Web Client ID (NOT the Android one). This is what
# @react-native-google-signin/google-signin needs as `webClientId`. On
# Android, the ID token returned by signIn() will have aud=this value,
# which the backend's /api/auth/google/idtoken verifies against.
#
# Get this from Google Cloud Console → APIs & Services → Credentials →
# the OAuth 2.0 Client ID of type "Web application" (the same one your
# web app uses for browser Google sign-in).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
